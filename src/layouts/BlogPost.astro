---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prev?: CollectionEntry<'blog'> | null;
	next?: CollectionEntry<'blog'> | null;
};

const { title, description, pubDate, updatedDate, featuredImage, categories, prev, next } = Astro.props;

const slugify = (s: string) =>
	s.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2em;
			}
			.date-row {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.5rem;
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85em;
			}
			.post-categories {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
			}
			.post-category {
				display: inline-block;
				padding: 0.2rem 0.65rem;
				border-radius: 999px;
				background: color-mix(in srgb, var(--accent) 12%, #fff);
				color: var(--accent-dark);
				font-size: 0.9rem;
				font-weight: 700;
				letter-spacing: 0.01em;
				text-decoration: none;
				transition: background 0.15s ease, color 0.15s ease;
			}
			.post-category:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.post-nav {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 1rem;
				margin-top: 2em;
				padding-top: 1em;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.9rem;
			}
			.post-nav .nav-prev,
			.post-nav .nav-next {
				display: flex;
				flex-direction: column;
				max-width: 45%;
			}
			.post-nav .nav-prev {
				text-align: left;
			}
			.post-nav .nav-next {
				text-align: right;
				margin-left: auto;
			}
			.post-nav a {
				color: var(--accent);
				text-decoration: none;
			}
			.post-nav a:hover {
				text-decoration: underline;
			}
			.nav-label {
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
				margin-bottom: 0.2em;
			}

		</style>
	</head>

	<body>
		<Header />
		<main id="main-content">
			<article>
				<div class="hero-image">
					{featuredImage && <Image width={400} height={200} src={featuredImage} alt="" loading={'eager'}/>}
				</div>
				<div class="prose" {...Astro.url.pathname.startsWith('/blog/') && { 'data-pagefind-body': true }}>
					<div class="title">
						<h1>{title}</h1>
						<div class="date-row">
							<div>
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
							{categories && categories.length > 0 && (
								<div class="post-categories">
									{categories.map((cat) => (
										<a class="post-category" href={`/blog/category/${slugify(cat)}/`}>{cat}</a>
									))}
								</div>
							)}
						</div>
						<hr />
					</div>
					<slot />
					{(prev || next) && (
						<nav class="post-nav">
							{prev && (
								<div class="nav-prev">
									<span class="nav-label">Previous</span>
									<a href={`/blog/${prev.id}/`}>{prev.data.title}</a>
								</div>
							)}
							{next && (
								<div class="nav-next">
									<span class="nav-label">Next</span>
									<a href={`/blog/${next.id}/`}>{next.data.title}</a>
								</div>
							)}
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
