---
import { SITE_TITLE } from '../consts';
import NavLinks from './NavLinks.astro';
import { Image } from 'astro:assets';

const heroImage = import('../assets/background-operate.png');
---

<header>
	<div>
		{heroImage && <Image width={1020} height={510} src={heroImage} alt="Me in operating room" loading={'eager'} />}
	</div>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<NavLinks />
	</nav>
</header>
<style>
	header {
		margin: 1em;
		padding: 0 2em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--black);
	}
	img {
		display: flex;
		width: 80%;
		height: auto;
		border-radius: 12px;
		margin: 1em auto 0 auto;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
</style>
