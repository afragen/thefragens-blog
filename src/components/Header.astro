---
import { SITE_TITLE } from '../consts';
import NavLinks from './NavLinks.astro';
import Search from './Search.astro';
import { Image } from 'astro:assets';

const heroImage = import('../assets/background-operate.png');
---

<a href="#main-content" class="skip-link">Skip to main content</a>
<header>
	<div>
		{heroImage && <Image width={1020} height={510} src={heroImage} alt="Me in operating room" loading={'eager'} />}
	</div>
	<nav>
		<p class="site-title"><a href="/">{SITE_TITLE}</a></p>
		<NavLinks />
	</nav>
</header>
<Search />
<style>
	header {
		margin: 1em;
		padding: 0 2em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	.site-title {
		margin: 0;
		font-size: 1.5em;
		font-weight: 700;
	}

	.site-title a,
	.site-title a.active {
		text-decoration: none;
		color: var(--black);
	}
	img {
		display: flex;
		width: 80%;
		height: auto;
		border-radius: 12px;
		margin: 1em auto 0 auto;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.skip-link {
		position: absolute;
		top: -100%;
		left: 0;
		padding: 0.5em 1em;
		background: var(--accent);
		color: #fff;
		font-weight: 700;
		text-decoration: none;
		z-index: 99999;
		border-radius: 0 0 6px 0;
		transition: top 0.1s;
	}
	.skip-link:focus {
		top: 0;
	}
</style>
