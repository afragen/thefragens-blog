---
import { SITE_TITLE } from '../consts';
import NavLinks from './NavLinks.astro';
import Search from './Search.astro';
import { Image } from 'astro:assets';
import heroImageSrc from '../assets/background-operate.png';
---

<a href="#main-content" class="skip-link">Skip to main content</a>
<header>
	<div>
		<Image src={heroImageSrc} widths={[400, 750, 1020]} sizes="100vw" alt="Me in operating room" format="webp" loading="eager" fetchpriority="high" />
	</div>
	<nav>
		<p class="site-title"><a href="/">{SITE_TITLE}</a></p>
		<NavLinks />
	</nav>
	<link rel="me" href="https://wptoots.social/@andyfragen">
</header>
<Search />
<style>
	header {
		margin: 1em;
		padding: 0 2em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	.site-title {
		margin: 0;
		font-size: 1.5em;
		font-weight: 700;
	}
	@media (max-width: 720px), (max-height: 500px) and (orientation: landscape) {
		.site-title {
			font-size: 1em;
		}
	}

	.site-title a,
	.site-title a.active {
		text-decoration: none;
		color: var(--black);
	}
	header > div {
		margin: 0 -2em;
	}
	img {
		display: flex;
		width: 100%;
		height: auto;
		margin: 0;
		border-radius: 0;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.skip-link {
		position: absolute;
		top: -100%;
		left: 0;
		padding: 0.5em 1em;
		background: var(--accent);
		color: #fff;
		font-weight: 700;
		text-decoration: none;
		z-index: 99999;
		border-radius: 0 0 6px 0;
		transition: top 0.1s;
	}
	.skip-link:focus {
		top: 0;
	}
</style>
