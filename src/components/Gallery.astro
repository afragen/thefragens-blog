---
/**
 * Gallery.astro
 *
 * Presentational gallery using Astro's <Image> component with a built-in
 * lightbox. No external dependencies — uses the native <dialog> element for
 * proper scoping, accessibility, and browser-managed backdrop.
 *
 * CSS is fully scoped via Astro's default component scoping. The only
 * global rule is `dialog::backdrop` which must be global by spec.
 *
 * Props:
 *   images   – ImageMetadata[]  — pass mod.default from import.meta.glob
 *   title    – optional heading above the grid
 *   columns  – preferred number of columns (default 3, min 2)
 *
 * Usage in MDX:
 *   export const imageModules = import.meta.glob(
 *     './images/*.{jpg,jpeg,png,gif,webp,avif}',
 *     { eager: true }
 *   )
 *   export const images = Object.values(imageModules).map(m => m.default)
 *
 *   <Gallery {images} title="Photos" columns={3} />
 */

import { getImage, Image } from 'astro:assets'

type Props = {
  images: ImageMetadata[]
  title?: string
  columns?: number
}

const { images = [], title, columns = 3 } = Astro.props
const cols = Math.max(2, columns)

// Unique ID per gallery instance so multiple galleries on a page don't collide
const uid = `gallery-${Math.random().toString(36).slice(2, 8)}`
const dialogId = `${uid}-lb`

function altFromFilename(src: string): string {
  return src
    .split('/').pop()!
    .replace(/\.[^.]+$/, '')
    .replace(/[-_]/g, ' ')
}

const items = await Promise.all(images.map(async (img) => {
  const full = await getImage({ src: img, format: 'webp', quality: 85 })
  return {
    img,
    fullSrc: full.src,
    alt: altFromFilename(img.src),
    isLandscape: img.width >= img.height,
  }
}))
---

<section class="gallery" data-gallery-id={uid}>
  {title && <h2 class="gallery__title">{title}</h2>}

  {items.length === 0 ? (
    <p class="gallery__empty">No images to display.</p>
  ) : (
    <div class="gallery__grid" style={`--cols: ${cols}`}>
      {items.map(({ img, alt, isLandscape }, i) => (
        <figure class:list={['gallery__item', isLandscape ? 'landscape' : 'portrait']}>
          <button
            class="gallery__btn"
            type="button"
            data-index={i}
            aria-label={`View ${alt}`}
            aria-haspopup="dialog"
            aria-controls={dialogId}
          >
            <Image
              class="gallery__img"
              src={img}
              alt={alt}
              width={800}
              height={600}
              format="webp"
              quality={80}
            />
            <span class="gallery__overlay" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <polyline points="15 3 21 3 21 9"/>
                <polyline points="9 21 3 21 3 15"/>
                <line x1="21" y1="3" x2="14" y2="10"/>
                <line x1="3" y1="21" x2="10" y2="14"/>
              </svg>
            </span>
          </button>
          <figcaption class="gallery__caption">{alt}</figcaption>
        </figure>
      ))}
    </div>
  )}
</section>

<!-- Native <dialog> — browser handles backdrop, focus trap, and Escape key -->
<dialog class="lb" id={dialogId} aria-label="Image lightbox">
  <button class="lb__close" aria-label="Close lightbox" type="button" autofocus>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="22" height="22" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <button class="lb__prev" aria-label="Previous image" type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="24" height="24" aria-hidden="true">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>

  <div class="lb__stage">
    <img class="lb__img" src="" alt="" />
  </div>

  <button class="lb__next" aria-label="Next image" type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="24" height="24" aria-hidden="true">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

  <footer class="lb__footer">
    <span class="lb__caption" aria-live="polite"></span>
    <span class="lb__counter" aria-live="polite"></span>
  </footer>
</dialog>

<!-- Image data serialised for the scoped script -->
<script
  type="application/json"
  data-gallery-data={uid}
  set:html={JSON.stringify(items.map(({ fullSrc, alt }) => ({ src: fullSrc, alt })))}
/>

<script>
  document.querySelectorAll<HTMLElement>('[data-gallery-id]').forEach((section) => {
    const uid     = section.dataset.galleryId!
    const dialog  = document.getElementById(`${uid}-lb`) as HTMLDialogElement | null
    const dataEl  = document.querySelector<HTMLScriptElement>(`[data-gallery-data="${uid}"]`)
    if (!dialog || !dataEl) return

    const imageList: { src: string; alt: string }[] = JSON.parse(dataEl.textContent ?? '[]')
    const lbImg     = dialog.querySelector<HTMLImageElement>('.lb__img')!
    const lbCaption = dialog.querySelector<HTMLElement>('.lb__caption')!
    const lbCounter = dialog.querySelector<HTMLElement>('.lb__counter')!
    let current = 0

    function show(index: number) {
      current = (index + imageList.length) % imageList.length
      const { src, alt } = imageList[current]
      dialog!.setAttribute('data-loading', '')
      lbImg.onload = lbImg.onerror = () => dialog!.removeAttribute('data-loading')
      lbImg.src = src
      lbImg.alt = alt
      lbCaption.textContent = alt
      lbCounter.textContent = `${current + 1} / ${imageList.length}`
    }

    function open(index: number) {
      show(index)
      dialog!.showModal()           // native dialog: handles focus trap + Escape
    }

    function close() {
      dialog!.close()
      // Return focus to the thumbnail that opened the lightbox
      section.querySelector<HTMLButtonElement>(`[data-index="${current}"]`)?.focus()
    }

    // Thumbnail buttons
    section.querySelectorAll<HTMLButtonElement>('[data-index]').forEach((btn) => {
      btn.addEventListener('click', () => open(Number(btn.dataset.index)))
    })

    // Prev / next
    dialog.querySelector('.lb__prev')?.addEventListener('click', () => show(current - 1))
    dialog.querySelector('.lb__next')?.addEventListener('click', () => show(current + 1))

    // Close button
    dialog.querySelector('.lb__close')?.addEventListener('click', close)

    // Click backdrop (the dialog element itself outside the content area)
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close()
    })

    // Escape is handled natively by <dialog> — wire 'close' event for focus return
    dialog.addEventListener('close', () => {
      section.querySelector<HTMLButtonElement>(`[data-index="${current}"]`)?.focus()
    })

    // Arrow key navigation (dialog already traps focus so keydown fires here)
    dialog.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); show(current + 1) }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); show(current - 1) }
    })

    // Touch swipe
    let touchStartX = 0
    dialog.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX }, { passive: true })
    dialog.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX
      if (Math.abs(dx) > 50) dx < 0 ? show(current + 1) : show(current - 1)
    })
  })
</script>

<style>
  /* ── Gallery grid ────────────────────────────────────────────────────────
     All selectors here are automatically scoped by Astro to this component
     via data-astro-cid-* attributes. Nothing leaks to the page.
  ── */
  .gallery {
    --gap: 6px;
    --radius: 5px;
    width: 100%;
    margin: 2rem 0;
  }

  .gallery__title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .gallery__empty {
    color: #888;
    font-style: italic;
    padding: 2rem 0;
  }

  .gallery__grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap);
  }

  .gallery__item {
    flex: 1 1 calc((100% - var(--gap) * (var(--cols) - 1)) / var(--cols));
    max-width: calc((100% - var(--gap) * (var(--cols) - 1)) / var(--cols));
    min-width: 0;
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius);
    background: #111;
    line-height: 0;
  }

  .gallery__btn {
    display: block;
    position: relative;
    overflow: hidden;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
  }

  .gallery__img {
    display: block;
    width: 100%;
    height: 200px;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius) var(--radius) 0 0;
    transition: transform 0.35s ease, filter 0.35s ease;
  }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    opacity: 0;
    transition: opacity 0.25s ease;
    border-radius: var(--radius) var(--radius) 0 0;
  }

  .gallery__btn:hover .gallery__img,
  .gallery__btn:focus-visible .gallery__img {
    transform: scale(1.05);
    filter: brightness(0.8);
  }

  .gallery__btn:hover .gallery__overlay,
  .gallery__btn:focus-visible .gallery__overlay {
    opacity: 1;
  }

  .gallery__caption {
    display: block;
    line-height: 1.4;
    padding: 0.3rem 0.5rem;
    font-size: 0.7rem;
    color: #ccc;
    background: rgba(0, 0, 0, 0.6);
    border-radius: 0 0 var(--radius) var(--radius);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-transform: capitalize;
  }

  @media (max-width: 600px) {
    .gallery__item {
      flex-basis: calc(50% - var(--gap) / 2) !important;
      max-width:  calc(50% - var(--gap) / 2) !important;
    }
    .gallery__img { height: 140px; }
  }

  @media (max-width: 360px) {
    .gallery__item { flex-basis: 100% !important; max-width: 100% !important; }
  }

  @media (min-width: 1024px) {
    .gallery__img { height: 240px; }
  }

  /* ── Lightbox (native <dialog>) ──────────────────────────────────────────
     <dialog> is part of this component's template so Astro scopes these
     selectors automatically. The only thing that can't be scoped is
     ::backdrop which is in <style is:global> below.
  ── */
  .lb {
    /* Reset browser dialog defaults */
    border: none;
    padding: 0;
    background: transparent;
    /* position: fixed takes the dialog out of normal flow so it cannot
       affect the width of sibling elements like <header> and <footer>. */
    position: fixed;
    inset: 0;
    max-width: 100vw;
    max-height: 100dvh;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;

    /* Flex layout for the lightbox content */
    display: none;             /* overridden by [open] below */
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    box-sizing: border-box;
  }

  .lb[open] {
    display: flex;
  }

  .lb[data-loading] .lb__img {
    opacity: 0.35;
  }

  .lb__stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    width: 100%;
  }

  .lb__img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 4px;
    transition: opacity 0.2s ease;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
  }

  .lb__close,
  .lb__prev,
  .lb__next {
    position: fixed;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    line-height: 0;
    transition: background 0.2s ease;
    z-index: 1;
  }

  .lb__close:hover,
  .lb__prev:hover,
  .lb__next:hover,
  .lb__close:focus-visible,
  .lb__prev:focus-visible,
  .lb__next:focus-visible {
    background: rgba(255, 255, 255, 0.28);
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 2px;
  }

  .lb__close { top: 1rem; right: 1rem; }
  .lb__prev  { left: 1rem;  top: 50%; transform: translateY(-50%); }
  .lb__next  { right: 1rem; top: 50%; transform: translateY(-50%); }

  .lb__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .lb__caption {
    color: #ddd;
    font-size: 0.875rem;
    text-align: center;
    text-transform: capitalize;
    max-width: 60ch;
  }

  .lb__counter {
    color: #777;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 600px) {
    .lb__close { top: 0.5rem; right: 0.5rem; }
    .lb__prev  { left: 0.25rem; }
    .lb__next  { right: 0.25rem; }

    .lb__stage {
      /* Inset the image so it isn't hidden behind the nav buttons */
      padding: 0 3rem;
    }

    .lb__caption {
      font-size: 0.75rem;
      max-width: 80vw;
    }
  }

  /*
   * ::backdrop is part of the browser's UA shadow DOM and cannot receive
   * Astro's scoping attribute. :global() lets us target it from within this
   * scoped <style> block without making the entire block global.
   * The selector is specific enough (dialog.lb::backdrop) that it won't
   * match any other element on the page.
   */
  :global(dialog.lb::backdrop) {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(2px);
  }
</style>
