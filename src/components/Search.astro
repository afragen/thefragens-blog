---
// Pagefind search modal — included once in Header.astro
// Pagefind index is generated automatically by astro-pagefind on `npm run build`
---

<div id="search-overlay" class="search-overlay" hidden role="dialog" aria-modal="true" aria-label="Search posts">
	<div id="search-backdrop" class="search-backdrop"></div>
	<div class="search-modal">
		<div id="pagefind-search"></div>
	</div>
</div>

<style>
	.search-overlay {
		position: fixed;
		inset: 0;
		z-index: 9000;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 10vh;
	}
	.search-overlay[hidden] {
		display: none;
	}
	.search-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
	}
	.search-modal {
		position: relative;
		z-index: 1;
		width: min(680px, 90vw);
		background: #fff;
		border-radius: 16px;
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.28);
		overflow: hidden;
	}

	/* ── Pagefind UI overrides ─────────────────────────────────────── */
	#pagefind-search {
		--pagefind-ui-scale: 1;
		--pagefind-ui-primary: var(--accent);
		--pagefind-ui-text: #111827;
		--pagefind-ui-background: #fff;
		--pagefind-ui-border: #f0f0f0;
		--pagefind-ui-tag: #f3f4f6;
		--pagefind-ui-border-width: 0px;
		--pagefind-ui-border-radius: 0px;
		--pagefind-ui-font: inherit;
	}
	#pagefind-search :global(.pagefind-ui) {
		width: 100%;
	}
	#pagefind-search :global(.pagefind-ui__form) {
		display: flex;
		align-items: center;
		padding: 0.85rem 1rem;
		border-bottom: 1px solid #f0f0f0;
	}
	#pagefind-search :global(.pagefind-ui__search-input) {
		flex: 1;
		border: none !important;
		outline: none !important;
		box-shadow: none !important;
		font-size: 1.05rem;
		padding: 0 0.5rem !important;
		background: transparent;
		color: #111;
	}
	#pagefind-search :global(.pagefind-ui__search-input::placeholder) {
		color: #9ca3af;
	}
	#pagefind-search :global(.pagefind-ui__search-clear) {
		background: none;
		border: none;
		color: #9ca3af;
		cursor: pointer;
		padding: 0 0.25rem;
	}
	#pagefind-search :global(.pagefind-ui__results-area) {
		max-height: 62vh;
		overflow-y: auto;
		padding: 0.5rem 0;
		margin: 0;
	}
	#pagefind-search :global(.pagefind-ui__result) {
		padding: 0.85rem 1.25rem;
		border-bottom: 1px solid #f3f4f6;
		list-style: none;
	}
	#pagefind-search :global(.pagefind-ui__result:last-child) {
		border-bottom: none;
	}
	#pagefind-search :global(.pagefind-ui__result:hover) {
		background: #f9fafb;
	}
	#pagefind-search :global(.pagefind-ui__result-link) {
		font-weight: 700;
		font-size: 1rem;
		color: #111827;
		text-decoration: none;
	}
	#pagefind-search :global(.pagefind-ui__result-link:hover) {
		color: var(--accent);
	}
	#pagefind-search :global(.pagefind-ui__result-excerpt) {
		font-size: 0.84rem;
		color: #6b7280;
		line-height: 1.55;
		margin-top: 0.25rem;
	}
	#pagefind-search :global(mark) {
		background: #fef08a;
		color: inherit;
		border-radius: 2px;
		padding: 0 1px;
	}
	#pagefind-search :global(.pagefind-ui__message) {
		padding: 1.25rem;
		color: #6b7280;
		font-size: 0.9rem;
		text-align: center;
	}
	#pagefind-search :global(.pagefind-ui__button) {
		display: block;
		margin: 0.75rem auto;
		padding: 0.5rem 1.5rem;
		background: var(--accent);
		color: #fff;
		border: none;
		border-radius: 999px;
		font-size: 0.88rem;
		cursor: pointer;
	}
</style>

<!--
  is:inline bypasses Vite bundling so the dynamic import of /pagefind/pagefind-ui.js
  is never statically resolved — it only runs at runtime after a production build.
-->
<script is:inline>
	var __searchOverlay   = document.getElementById('search-overlay');
	var __searchBackdrop  = document.getElementById('search-backdrop');
	var __pagefindLoaded  = false;

	async function __initPagefind() {
		if (__pagefindLoaded) return;
		__pagefindLoaded = true;
		try {
			var pf = await import('/pagefind/pagefind-ui.js');
			new pf.PagefindUI({
				element: '#pagefind-search',
				showSubResults: true,
				showImages: false,
				resetStyles: true,
			});
		} catch {
			document.getElementById('pagefind-search').innerHTML =
				'<p style="padding:1.25rem;color:#6b7280;text-align:center;font-size:0.9rem">' +
				'Search requires a production build.<br>' +
				'Run <code style="background:#f3f4f6;padding:0.1em 0.4em;border-radius:4px">npm run build</code> to enable it.' +
				'</p>';
		}
		requestAnimationFrame(function() {
			var inp = __searchOverlay.querySelector('.pagefind-ui__search-input');
			if (inp) inp.focus();
		});
	}

	function __openSearch() {
		__searchOverlay.hidden = false;
		document.body.style.overflow = 'hidden';
		__initPagefind();
	}

	function __closeSearch() {
		__searchOverlay.hidden = true;
		document.body.style.overflow = '';
	}

	__searchBackdrop.addEventListener('click', __closeSearch);

	document.addEventListener('keydown', function(e) {
		if (e.key === 'Escape' && !__searchOverlay.hidden) { __closeSearch(); return; }
		if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
			e.preventDefault();
			__searchOverlay.hidden ? __openSearch() : __closeSearch();
		}
	});

	document.addEventListener('search:open', __openSearch);
</script>
