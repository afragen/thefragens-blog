---
// Search modal — uses pagefind.js engine directly (not pagefind-ui.js)
// Triggered by NavLinks dispatching 'search:open' or Cmd/Ctrl+K
---

<dialog id="search-modal" class="search-modal" data-pagefind-ignore="all">
	<div class="search-backdrop" data-close-modal></div>
	<div class="search-content">
		<div class="search-header">
			<div class="search-input-wrapper">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
					viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
					stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="11" cy="11" r="8"/>
					<path d="m21 21-4.3-4.3"/>
				</svg>
				<input
					id="search-input"
					type="text"
					placeholder="Search…"
					aria-label="Search this site"
					autocomplete="off"
					class="search-input"
				/>
				<kbd class="search-kbd">Esc</kbd>
			</div>
		</div>
		<div id="search-results" class="search-results" aria-live="polite" aria-label="Search results"></div>
	</div>
</dialog>

<style is:inline>
	.search-modal {
		padding: 0;
		border: none;
		background: transparent;
		max-width: 100vw;
		max-height: 100vh;
		width: 100vw;
		height: 100vh;
		position: fixed;
		inset: 0;
	}
	.search-modal::backdrop {
		display: none;
	}

	.search-backdrop {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
	}

	.search-content {
		position: relative;
		margin: 10vh auto 0;
		width: min(680px, 90vw);
		max-height: 70vh;
		background: #fff;
		border-radius: 16px;
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.28);
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	.search-header {
		padding: 1rem 1.25rem;
		border-bottom: 1px solid #f0f0f0;
		flex-shrink: 0;
	}

	.search-input-wrapper {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.search-icon {
		flex-shrink: 0;
		color: #9ca3af;
	}

	.search-input {
		flex: 1;
		border: none;
		outline: none;
		font-size: 1.1rem;
		background: transparent;
		color: #111;
		font-family: inherit;
	}
	.search-input::placeholder {
		color: #9ca3af;
	}

	.search-kbd {
		flex-shrink: 0;
		padding: 2px 8px;
		font-size: 0.75rem;
		font-family: inherit;
		border: 1px solid #e5e7eb;
		border-radius: 4px;
		color: #9ca3af;
		background: #f9fafb;
	}

	.search-results {
		overflow-y: auto;
		flex: 1;
		padding: 0.25rem 0;
	}
	.search-results:empty {
		display: none;
	}

	/* ── Result items ───────────────────────────────────────────── */
	.search-results :global(.search-result) {
		padding: 0.85rem 1.25rem;
		border-bottom: 1px solid #f3f4f6;
	}
	.search-results :global(.search-result:last-child) {
		border-bottom: none;
	}
	.search-results :global(.search-result > a) {
		text-decoration: none;
		display: block;
	}
	.search-results :global(.search-result-title) {
		font-weight: 700;
		font-size: 1rem;
		color: #111827;
		margin-bottom: 0.25rem;
	}
	.search-results :global(.search-result > a:hover .search-result-title) {
		color: var(--accent);
	}
	.search-results :global(.search-result-excerpt) {
		font-size: 0.84rem;
		color: #6b7280;
		line-height: 1.55;
	}
	.search-results :global(mark) {
		background: #fef08a;
		color: inherit;
		border-radius: 2px;
		padding: 0 1px;
	}
	.search-results :global(.search-sub-results) {
		margin-top: 0.5rem;
		margin-left: 1rem;
		padding-left: 0.75rem;
		border-left: 2px solid #e5e7eb;
	}
	.search-results :global(.search-sub-result) {
		display: block;
		padding: 0.35rem 0;
		text-decoration: none;
	}
	.search-results :global(.search-sub-result-title) {
		display: block;
		font-weight: 500;
		font-size: 0.875rem;
		color: #374151;
	}
	.search-results :global(.search-sub-result:hover .search-sub-result-title) {
		color: var(--accent);
	}
	.search-results :global(.search-sub-result-excerpt) {
		display: block;
		font-size: 0.8rem;
		color: #9ca3af;
		line-height: 1.4;
	}
	.search-results :global(.search-no-results) {
		padding: 1.5rem;
		text-align: center;
		color: #9ca3af;
		font-size: 0.9rem;
	}
</style>

<script is:inline>
	(function () {
		var dialog = document.getElementById('search-modal');
		var input  = document.getElementById('search-input');
		var resultsEl = document.getElementById('search-results');
		var backdrop  = dialog && dialog.querySelector('[data-close-modal]');

		if (!dialog || !input || !resultsEl) return;

		var pagefind = null;
		var debounceTimer = null;

		async function loadPagefind() {
			if (pagefind) return pagefind;
			try {
				var pf = await import('/pagefind/pagefind.js');
				await pf.init();
				pagefind = pf;
			} catch (e) {
				console.error('Failed to load Pagefind', e);
			}
			return pagefind;
		}

		function openModal() {
			dialog.showModal();
			input.value = '';
			resultsEl.innerHTML = '';
			input.focus();
			loadPagefind();
		}

		function closeModal() {
			dialog.close();
		}

		// Cmd/Ctrl+K
		document.addEventListener('keydown', function (e) {
			if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
				e.preventDefault();
				dialog.open ? closeModal() : openModal();
			}
		});

		// Backdrop click closes
		backdrop && backdrop.addEventListener('click', closeModal);

		// Clean up on native close (Escape or .close())
		dialog.addEventListener('close', function () {
			input.value = '';
			resultsEl.innerHTML = '';
		});

		// Debounced search
		input.addEventListener('input', function () {
			clearTimeout(debounceTimer);
			debounceTimer = setTimeout(async function () {
				var query = input.value.trim();
				if (!query) {
					resultsEl.innerHTML = '';
					return;
				}

				var pf = await loadPagefind();
				if (!pf) return;

				var search = await pf.search(query);
				var results = await Promise.all(
					search.results.slice(0, 8).map(function (r) { return r.data(); })
				);

				if (results.length === 0) {
					resultsEl.innerHTML =
						'<p class="search-no-results">No results for \u201c' + query + '\u201d</p>';
					return;
				}

				resultsEl.innerHTML = results.map(function (r) {
					var subHtml = (r.sub_results || [])
						.filter(function (s) { return s.url !== r.url; })
						.slice(0, 3)
						.map(function (s) {
							return '<a href="' + s.url + '" class="search-sub-result">' +
								'<span class="search-sub-result-title">' + s.title + '</span>' +
								'<span class="search-sub-result-excerpt">' + s.excerpt + '</span>' +
								'</a>';
						}).join('');
					return '<div class="search-result">' +
						'<a href="' + r.url + '">' +
							'<div class="search-result-title">' + (r.meta && r.meta.title || r.url) + '</div>' +
							'<div class="search-result-excerpt">' + r.excerpt + '</div>' +
						'</a>' +
						(subHtml ? '<div class="search-sub-results">' + subHtml + '</div>' : '') +
						'</div>';
				}).join('');
			}, 200);
		});

		// Enter → navigate to first result
		input.addEventListener('keydown', function (e) {
			if (e.key === 'Enter') {
				var firstLink = resultsEl.querySelector('a');
				if (firstLink) {
					closeModal();
					window.location.href = firstLink.getAttribute('href') || '';
				}
			}
		});

		// NavLinks search button dispatches this event
		document.addEventListener('search:open', openModal);
	})();
</script>
