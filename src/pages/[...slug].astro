---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
	const blogPaths = posts.map((post) => ({
		params: { slug: post.id },
		props: { type: 'blog' as const, post },
	}));

	const pages = await getCollection('pages');
	const pagePaths = pages.map((page) => ({
		params: { slug: page.id.replace(/\/index$/, '') },
		props: { type: 'page' as const, page },
	}));

	return [...blogPaths, ...pagePaths];
}

type Props =
	| { type: 'blog'; post: CollectionEntry<'blog'>; page?: never }
	| { type: 'page'; page: CollectionEntry<'pages'>; post?: never };

const { type, post, page } = Astro.props;

let Content: any;
let frontmatter: { title: string; description?: string; pubDate?: Date; updatedDate?: Date; heroImage?: any };

if (type === 'blog') {
	({ Content } = await render(post));
	frontmatter = post.data;
} else {
	({ Content } = await render(page));
	const { title, description, pubDate, date, updatedDate } = page.data;
	frontmatter = {
		title,
		description: description ?? '',
		pubDate: pubDate ?? date ?? new Date(),
		updatedDate,
	};
}
---

<BlogPost {...frontmatter}>
	<Content />
</BlogPost>
