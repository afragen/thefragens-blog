---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import BlogPlaceholder from '../../../components/BlogPlaceholder.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';
import { categoryPalette } from '../../../palette';

const slugify = (s: string) =>
	s.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');

export async function getStaticPaths() {
	const PAGE_SIZE = 12;
	const allPosts = (await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft)).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

	return Array.from({ length: totalPages - 1 }, (_, i) => {
		const page = i + 2;
		return {
			params: { page: String(page) },
			props: {
				posts: allPosts.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE),
				currentPage: page,
				totalPages,
			},
		};
	});
}

const { posts, currentPage, totalPages } = Astro.props;

let winStart = Math.max(1, currentPage - 3);
let winEnd = winStart + 7;
if (winEnd > totalPages) {
	winEnd = totalPages;
	winStart = Math.max(1, winEnd - 7);
}
const pageWindow = Array.from({ length: winEnd - winStart + 1 }, (_, i) => winStart + i);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Page ${currentPage}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.posts-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.posts-grid li {
				flex: 1 1 260px;
				max-width: calc(33.333% - 1rem);
				min-width: 260px;
			}
			.post-card {
				display: flex;
				flex-direction: column;
				height: 100%;
				border-radius: 12px;
				overflow: hidden;
				background: #fff;
				box-shadow: 0 1px 4px rgba(0,0,0,0.08);
				border: 2px solid transparent;
				transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
			}
			.post-card:hover {
				box-shadow:
					0 4px 16px color-mix(in srgb, black 15%, white),
					inset 0 0 0 1px rgba(255,255,255,0.12);
				transform: scale(1.03);
			}
			a.card-image {
				display: block;
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: #eee;
			}
			a.card-image img, a.card-image svg {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
				display: block;
			}
			.card-body {
				padding: 1rem 1.1rem 1.1rem;
				display: flex;
				flex-direction: column;
				flex: 1;
			}
			.card-footer {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 0.5rem;
				margin-top: auto;
				padding-top: 0.75rem;
			}
			.card-categories {
				display: flex;
				flex-wrap: wrap;
				justify-content: flex-end;
				gap: 0.4rem;
				margin: 0;
			}
			.card-category {
				display: inline-block;
				padding: 0.25rem 0.75rem;
				border-radius: 999px;
				background: color-mix(in srgb, var(--accent) 12%, #fff);
				color: var(--accent-dark);
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.01em;
				text-decoration: none;
				transition: background 0.15s ease, color 0.15s ease;
			}
			.card-category:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.card-title {
				margin: 0 0 0.5rem;
				font-size: 1.4rem;
				font-weight: 700;
				line-height: 1.3;
				text-align: center;
			}
			.card-link {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.card-description {
				margin: 0 0 0.5rem;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.card-date {
				margin: 0;
				font-size: 0.82rem;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 0.4rem;
				margin: 2.5rem 0 1rem;
			}
			.pagination a,
			.pagination span.current {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 2.4rem;
				height: 2.4rem;
				border-radius: 50%;
				font-size: 0.9rem;
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.pagination a {
				background: rgb(var(--gray-light));
				color: rgb(var(--black));
			}
			.pagination a:hover {
				background: rgb(var(--gray));
				color: #fff;
			}
			.pagination span.current {
				background: var(--accent-dark);
				color: #fff;
				font-weight: 600;
			}
			@media (max-width: 720px) {
				.posts-grid li {
					max-width: 100%;
					min-width: 0;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section>
				<ul class="posts-grid">
					{
						posts.map((post) => (
							<li>
								<div class="post-card">
									<a class="card-image" href={`/blog/${post.id}/`} aria-label={post.data.title}>
										{(() => {
											const cats = post.data.categories ?? [];
											const colors = cats.map(cat => categoryPalette[slugify(cat)]).filter(Boolean);
											return <BlogPlaceholder accents={colors.map(c => c.accent)} accentDarks={colors.map(c => c.accentDark)} seed={post.id} />;
										})()}
									</a>
									<div class="card-body">
										<h2 class="card-title">
											<a class="card-link" href={`/blog/${post.id}/`}>
												{post.data.title}
											</a>
										</h2>
										{post.data.description && (
											<p class="card-description">{post.data.description}</p>
										)}
										<div class="card-footer">
											<p class="card-date">
												<FormattedDate date={post.data.pubDate} />
											</p>
											{post.data.categories && post.data.categories.length > 0 && (
												<div class="card-categories">
													{post.data.categories.map((cat) => (
														<a
															class="card-category"
															href={`/blog/category/${slugify(cat)}/`}
														>
															{cat}
														</a>
													))}
												</div>
											)}
										</div>
									</div>
								</div>
							</li>
						))
					}
				</ul>
				<nav class="pagination" aria-label="Blog pagination">
					{currentPage === 2 ? (
						<a href="/" aria-label="Previous page">&larr;</a>
					) : (
						<a href={`/blog/page/${currentPage - 1}/`} aria-label="Previous page">&larr;</a>
					)}
					{pageWindow.map((p) =>
						p === currentPage ? (
							<span class="current" aria-current="page">{p}</span>
						) : p === 1 ? (
							<a href="/">1</a>
						) : (
							<a href={`/blog/page/${p}/`}>{p}</a>
						)
					)}
					{currentPage < totalPages && (
						<a href={`/blog/page/${currentPage + 1}/`} aria-label="Next page">&rarr;</a>
					)}
				</nav>
			</section>
		</main>
		<Footer />
	</body>
</html>
